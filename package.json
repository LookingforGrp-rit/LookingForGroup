{
  "name": "looking-for-group",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "license": "CC0-1.0",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "prepare": "husky && npm run prisma:generate",
    "compose:up": "npx dotenv -- docker compose --file=./containers/docker-compose.yml up --build -d",
    "compose:start": "npx dotenv -- docker compose --file=./containers/docker-compose.yml start",
    "compose:down": "npx dotenv -- docker compose --file=./containers/docker-compose.yml down -v",
    "compose:stop": "npx dotenv -- docker compose --file=./containers/docker-compose.yml stop",
    "prisma:pull": "npx dotenv -- cross-env DATABASE_URL='mysql://$DB_USER:$DB_PASS@$DB_HOST:$DB_PORT/$DB_NAME' npx prisma db pull --schema=server/prisma/schema.prisma",
    "prisma:reset": "npx dotenv -- cross-env DATABASE_URL='mysql://$DB_USER:$DB_PASS@$DB_HOST:$DB_PORT/$DB_NAME' npx prisma migrate reset --schema server/prisma --force",
    "prisma:generate": "npx prisma generate --schema=server/prisma/schema.prisma",
    "build:client": "npm run build --workspace=client",
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "docker:build": "docker build .",
    "docker:run": "concurrently \"docker run lookingforgroup\" \"npm run dev --workspace=client\"",
    "test:server": "npm run test --workspace=server",
    "test:client": "npm run test --workspace=client",
    "lint:server:types": "npm run lint:types --workspace=server",
    "lint:server": "npm run lint --workspace=server",
    "lint:client:types": "npm run lint:types --workspace=client",
    "lint:client": "npm run lint --workspace=client",
    "format:server": "npm run format --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prisma": "^6.19.3"
  },
  "engines": {
    "node": ">=v23.6.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.6.2",
    "balanced-match": "^4.0.4",
    "body-parser": "^2.2.2",
    "es-shim-unscopables": "^1.1.0",
    "eslint": "^9.39.4",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "swagger-parser": "^10.0.3",
    "tsx": "^4.20.5"
  }
}
